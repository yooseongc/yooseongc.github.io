---
import BlogLayout from '../layouts/BlogLayout.astro';
import { projectCategories } from '../data/projects';
import { ProjectCard } from '../components/ProjectCard';
---

<BlogLayout title="Projects" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-12 space-y-12">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Projects</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        GitHub에서 진행한 프로젝트 목록입니다.
      </p>
    </div>

    {projectCategories.map((category) => (
      <section>
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-1 flex items-center gap-2">
          <span class="w-1 h-5 bg-emerald-500 rounded-full inline-block"></span>
          {category.title}
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
          {category.description}
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {category.projects.map((p) => (
            <ProjectCard
              name={p.name}
              description={p.description}
              github={p.github}
              demo={p.demo}
              tags={p.tags}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BlogLayout>
