---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { PostCard } from '../../components/PostCard';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BlogLayout title="Journal" showTOC={false}>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Journal</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">
      일상적인 생각과 이야기를 나눕니다.
    </p>

    {posts.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400 text-sm">아직 작성된 글이 없습니다.</p>
    ) : (
      <div class="grid gap-4">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date.toISOString().slice(0, 10)}
            excerpt={post.data.excerpt}
            tags={post.data.tags}
            slug={post.id}
            basePath="/journal"
          />
        ))}
      </div>
    )}
  </div>
</BlogLayout>
