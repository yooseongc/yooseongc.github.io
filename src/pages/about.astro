---
import BlogLayout from '../layouts/BlogLayout.astro';
import { profile } from '../data/profile';
import { works } from '../data/works';
import { studies } from '../data/studies';
import { Timeline } from '../components/Timeline';
import { TechBadge } from '../components/TechBadge';
---

<BlogLayout title="About">
  <div class="max-w-3xl mx-auto px-6 py-12 space-y-14">
    <!-- Intro -->
    <section>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">About</h1>
      <p class="text-base text-gray-600 dark:text-gray-400">
        {profile.intro}. {profile.description}
      </p>
    </section>

    <!-- Work History -->
    <section>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Work History</h2>
      <Timeline entries={works} />
    </section>

    <!-- Current Focus -->
    <section>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Current Focus</h2>
      <ul class="space-y-2">
        {profile.currentFocus.map((item) => (
          <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0" />
            {item}
          </li>
        ))}
      </ul>
    </section>

    <!-- Studies -->
    <section>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Studies</h2>
      <div class="space-y-8">
        {studies.map((cat) => (
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 p-5">
            <h3 class="text-base font-semibold text-gray-900 dark:text-white">{cat.title}</h3>
            {cat.description && (
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">{cat.description}</p>
            )}
            <ul class="mt-4 space-y-3">
              {cat.topics.map((topic) => (
                <li>
                  <div class="text-sm font-medium text-gray-800 dark:text-gray-200">{topic.name}</div>
                  {topic.description && (
                    <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">{topic.description}</p>
                  )}
                  {topic.subtopics && (
                    <ul class="mt-1.5 ml-4 space-y-0.5">
                      {topic.subtopics.map((sub) => (
                        <li class="text-xs text-gray-500 dark:text-gray-500 flex items-start gap-1.5">
                          <span class="mt-1.5 w-1 h-1 rounded-full bg-gray-400 dark:bg-gray-600 shrink-0" />
                          {sub}
                        </li>
                      ))}
                    </ul>
                  )}
                  {topic.relatedTech && topic.relatedTech.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1">
                      {topic.relatedTech.map((tech) => (
                        <span class="inline-block rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-[10px] text-gray-500 dark:text-gray-400">{tech}</span>
                      ))}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Tech Stack -->
    <section>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Tech Stack</h2>
      <div class="space-y-3">
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-500 uppercase tracking-wider">Languages</span>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            {profile.techStack.languages.map((t) => (
              <TechBadge name={t.name} color={t.color} />
            ))}
          </div>
        </div>
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-500 uppercase tracking-wider">Infra</span>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            {profile.techStack.infra.map((t) => (
              <TechBadge name={t.name} color={t.color} />
            ))}
          </div>
        </div>
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-500 uppercase tracking-wider">ETC</span>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            {profile.techStack.etc.map((t) => (
              <TechBadge name={t.name} color={t.color} />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Links -->
    <section>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Links</h2>
      <div class="flex flex-wrap gap-4">
        <a
          href={profile.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          GitHub
        </a>
        <a
          href={`mailto:${profile.links.email}`}
          class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email
        </a>
      </div>
    </section>
  </div>
</BlogLayout>
