---
import BlogLayout from '../layouts/BlogLayout.astro';
import { profile } from '../data/profile';
import { projectCategories } from '../data/projects';
import { tools } from '../data/tools';
import { TechBadge } from '../components/TechBadge';
import { PostCard } from '../components/PostCard';
import { ProjectCard } from '../components/ProjectCard';
import { ToolCard } from '../components/ToolCard';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featuredProjects = projectCategories[0].projects.slice(0, 4);
const featuredTools = tools.slice(0, 4);
---

<BlogLayout showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-12 space-y-16">
    <!-- Hero -->
    <section>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{profile.name}</h1>
      <p class="mt-2 text-lg text-gray-600 dark:text-gray-400">{profile.intro}</p>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">{profile.description}</p>

      <div class="mt-6 flex flex-wrap gap-2">
        {profile.interests.map((interest) => (
          <span class="rounded-full border border-emerald-200 dark:border-emerald-800 bg-emerald-50 dark:bg-emerald-900/20 px-3 py-1 text-sm text-emerald-700 dark:text-emerald-400">
            {interest}
          </span>
        ))}
      </div>
    </section>

    <!-- Tech Stack -->
    <section>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Tech Stack</h2>
      <div class="space-y-3">
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-500 uppercase tracking-wider">Languages</span>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            {profile.techStack.languages.map((t) => (
              <TechBadge name={t.name} color={t.color} />
            ))}
          </div>
        </div>
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-500 uppercase tracking-wider">Infra</span>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            {profile.techStack.infra.map((t) => (
              <TechBadge name={t.name} color={t.color} />
            ))}
          </div>
        </div>
        <div>
          <span class="text-xs text-gray-500 dark:text-gray-500 uppercase tracking-wider">ETC</span>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            {profile.techStack.etc.map((t) => (
              <TechBadge name={t.name} color={t.color} />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Recent Posts -->
    {posts.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Recent Posts</h2>
          <a href="/blog" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">
            View all
          </a>
        </div>
        <div class="grid gap-4">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date.toISOString().slice(0, 10)}
              excerpt={post.data.excerpt}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Web Tools -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Web Tools</h2>
        <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">
          View all
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {featuredTools.map((tool) => (
          <ToolCard {...tool} />
        ))}
      </div>
    </section>

    <!-- Featured Projects -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Featured Projects</h2>
        <a href="/projects" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">
          View all
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {featuredProjects.map((p) => (
          <ProjectCard
            name={p.name}
            description={p.description}
            github={p.github}
            demo={p.demo}
            tags={p.tags}
          />
        ))}
      </div>
    </section>
  </div>
</BlogLayout>
