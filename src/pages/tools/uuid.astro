---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { UuidGenerator } from '../../components/tools/UuidGenerator';
---

<BlogLayout title="UUID Generator" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">UUID Generator</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">UUID v4/v5/v7 생성 및 파싱</p>
    </div>
    <UuidGenerator client:only="react" />
  </div>
</BlogLayout>
