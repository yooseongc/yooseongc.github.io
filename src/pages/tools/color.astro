---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { ColorPicker } from '../../components/tools/ColorPicker';
---

<BlogLayout title="Color Picker / Converter" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Color Picker / Converter</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">색상 변환 및 대비율 검사 도구</p>
    </div>
    <ColorPicker client:only="react" />
  </div>
</BlogLayout>
