---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { NetworkCalculator } from '../../components/tools/NetworkCalculator';
---

<BlogLayout title="네트워크 주소 계산기" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">네트워크 주소 계산기</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">IP 서브넷 계산 및 주소 범위 확인</p>
    </div>
    <NetworkCalculator client:only="react" />
  </div>
</BlogLayout>
