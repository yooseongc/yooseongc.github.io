---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { CronParser } from '../../components/tools/CronParser';
---
<BlogLayout title="Cron Parser" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Cron Parser</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Cron 표현식 파싱, 자연어 설명 및 실행 스케줄 확인</p>
    </div>
    <CronParser client:only="react" />
  </div>
</BlogLayout>
