---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { ProgrammerCalculator } from '../../components/tools/ProgrammerCalculator';
---

<BlogLayout title="프로그래머 계산기" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">프로그래머 계산기</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">진법 변환 및 비트 연산 계산기</p>
    </div>
    <ProgrammerCalculator client:only="react" />
  </div>
</BlogLayout>
