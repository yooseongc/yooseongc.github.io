---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { Base64Converter } from '../../components/tools/Base64Converter';
---

<BlogLayout title="Base64 Converter" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Base64 Converter</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Base64 인코딩/디코딩 변환기</p>
    </div>
    <Base64Converter client:only="react" />
  </div>
</BlogLayout>
