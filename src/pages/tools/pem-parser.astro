---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { PemParser } from '../../components/tools/PemParser';
---

<BlogLayout title="PEM Parser" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">PEM Parser</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">인증서 PEM 파일 파싱 및 상세 정보 표시</p>
    </div>
    <PemParser client:only="react" />
  </div>
</BlogLayout>
