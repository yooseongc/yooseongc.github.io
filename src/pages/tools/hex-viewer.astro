---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { HexViewer } from '../../components/tools/HexViewer';
---
<BlogLayout title="Hex Viewer" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Hex Viewer</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">텍스트 또는 파일의 hex dump를 클래식 포맷으로 표시</p>
    </div>
    <HexViewer client:only="react" />
  </div>
</BlogLayout>
