---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { UnixTimestamp } from '../../components/tools/UnixTimestamp';
---

<BlogLayout title="Unix Timestamp Converter" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Unix Timestamp Converter</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Unix epoch ↔ 날짜 양방향 변환</p>
    </div>
    <UnixTimestamp client:only="react" />
  </div>
</BlogLayout>
