---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { MarkdownRenderer } from '../../components/tools/MarkdownRenderer';
---

<BlogLayout title="Markdown Renderer" showTOC={false}>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">&larr; Tools</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Markdown Renderer</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Markdown 실시간 미리보기</p>
    </div>
    <MarkdownRenderer client:only="react" />
  </div>
</BlogLayout>
