---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { TagBadge } from '../../components/TagBadge';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Series navigation
let seriesPosts: { id: string; title: string }[] = [];
let currentIndex = -1;
if (post.data.series) {
  const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.series === post.data.series))
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  seriesPosts = allPosts.map((p) => ({ id: p.id, title: p.data.title }));
  currentIndex = seriesPosts.findIndex((p) => p.id === post.id);
}
const prevPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
const nextPost = currentIndex < seriesPosts.length - 1 ? seriesPosts[currentIndex + 1] : null;
---

<BlogLayout title={post.data.title}>
  <article class="max-w-5xl mx-auto px-6 py-12">
    <header class="mb-8">
      <time class="text-sm text-gray-500 dark:text-gray-500">
        {post.data.date.toISOString().slice(0, 10)}
      </time>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">
        {post.data.title}
      </h1>
      {post.data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {post.data.tags.map((tag: string) => (
            <TagBadge tag={tag} href={`/blog/tags/${tag}`} />
          ))}
        </div>
      )}
      {post.data.series && (
        <div class="mt-3 text-xs text-gray-500 dark:text-gray-400">
          시리즈: <span class="font-medium text-emerald-600 dark:text-emerald-400">{post.data.series}</span>
          {seriesPosts.length > 1 && ` (${currentIndex + 1}/${seriesPosts.length})`}
        </div>
      )}
    </header>

    <div class="blog-prose">
      <Content />
    </div>

    {/* Series navigation */}
    {(prevPost || nextPost) && (
      <nav class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800 grid grid-cols-2 gap-4">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="group">
            <span class="text-xs text-gray-400 dark:text-gray-500">이전 글</span>
            <p class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">&larr; {prevPost.title}</p>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}`} class="group text-right">
            <span class="text-xs text-gray-400 dark:text-gray-500">다음 글</span>
            <p class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">{nextPost.title} &rarr;</p>
          </a>
        ) : <div />}
      </nav>
    )}

    <footer class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-800">
      <a
        href="/blog"
        class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline"
      >
        &larr; Back to Blog
      </a>
    </footer>
  </article>
</BlogLayout>
